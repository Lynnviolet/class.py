    POLYMORPHISM
    class Animal:
    """Base class for animals with a move action."""
    def move(self):
        """Defines the general move action."""
        print("This animal is moving in a general way.")

class Dog(Animal):
    """Represents a dog with a specific move action."""
    def move(self):
        """Defines how a dog moves."""
        print("Running on four legs 🐕")

class Bird(Animal):
    """Represents a bird with a specific move action."""
    def move(self):
        """Defines how a bird moves."""
        print("Flying through the air 🐦")

class Fish(Animal):
    """Represents a fish with a specific move action."""
    def move(self):
        """Defines how a fish moves."""
        print("Swimming in the water 🐠")

class Car:
    """Represents a car with a specific move action."""
    def move(self):
        """Defines how a car moves."""
        print("Driving on the road 🚗")

class Airplane:
    """Represents an airplane with a specific move action."""
    def move(self):
        """Defines how an airplane moves."""
        print("Flying in the sky ✈️")

def let_it_move(thing):
    """Accepts an object and calls its move() method."""
    thing.move()
    
my_dog = Dog()
my_bird = Bird()
my_fish = Fish()
my_car = Car()
my_airplane = Airplane()


moving_objects = [my_dog, my_bird, my_fish, my_car, my_airplane]


print("--- Polymorphism in Action ---")
for obj in moving_objects:
    let_it_move(obj)
print("----------------------------")
